# ── Main user-management database ─────────────────────────────────────────────
POSTGRES_DB=ciosuseradd
POSTGRES_USER=ciosadmin
POSTGRES_PASSWORD=CHANGEME_strong_password_here

# ── FTP activity log database (separate container) ─────────────────────────────
LOGS_POSTGRES_DB=ftplogs
LOGS_POSTGRES_USER=logsadmin
LOGS_POSTGRES_PASSWORD=CHANGEME_separate_strong_password

# ── JWT & admin credentials ────────────────────────────────────────────────────
# Generate SECRET_KEY with: openssl rand -hex 32
# ADMIN_USERNAME and ADMIN_PASSWORD seed the DB on first start only.
# After first start, use the Settings panel in the admin UI to change them.
SECRET_KEY=CHANGEME_run_openssl_rand_hex_32_and_paste_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME_strong_admin_password

# ── ProFTPd virtual user config ────────────────────────────────────────────────
# Run: id <your_ftp_system_user>  on the FTP server to get UID/GID
FTP_UID=1001
FTP_GID=33
# Directory on the host containing ftpd.passwd (must exist before first run)
FTPD_PASSWD_DIR=/etc/proftpd

# ── CORS & network binding ─────────────────────────────────────────────────────
# Use * for testing. Set your actual HTTPS domain in production:
#   ALLOWED_ORIGINS=https://ftp.yourdomain.com
ALLOWED_ORIGINS=*
# BIND_IP: 0.0.0.0 = all interfaces (testing), 127.0.0.1 = localhost only,
#          or a specific LAN IP when NPM is on a different host
BIND_IP=127.0.0.1
LISTEN_PORT=8080

# ── FTP log directory ──────────────────────────────────────────────────────────
# The entire ProFTPd log directory is bind-mounted read-only into the logtailer.
# The specific log filename (default: full_user.log) is set in the Settings panel.
# Must match the directory containing your ExtendedLog files.
FTP_LOG_DIR=/var/log/proftpd
