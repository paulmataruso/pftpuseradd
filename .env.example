# PostgreSQL
POSTGRES_DB=ftpusers
POSTGRES_USER=ftpadmin
POSTGRES_PASSWORD=CHANGEME_strong_password_here

# JWT secret for admin session tokens
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGEME_run_openssl_rand_hex_32_and_paste_here

# Admin UI credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME_strong_admin_password

# UID/GID that ProFTPd virtual users map to on the host filesystem
# Run: id <your_ftp_system_user>  on the FTP server to get these values
FTP_UID=1001
FTP_GID=33

# Full path to the directory containing ftpd.passwd on the host
# Must match AuthUserFile in your proftpd.conf (minus the filename)
FTPD_PASSWD_DIR=/etc/proftpd

# CORS allowed origins
# Use * for testing, set your actual domain in production
# Example: https://ftp.yourdomain.com
ALLOWED_ORIGINS=*

# Network binding
# BIND_IP controls which interface nginx listens on:
#   0.0.0.0    = all interfaces (testing only, not recommended for production)
#   127.0.0.1  = localhost only (use when reverse proxy is on the same host)
#   192.168.x.x = specific LAN IP (use when reverse proxy is on another host)
BIND_IP=127.0.0.1
LISTEN_PORT=8080
